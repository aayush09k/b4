import 'dart:async';
import 'dart:convert';
import 'dart:io';
import 'package:crypto/crypto.dart';
import 'package:sqlite3/sqlite3.dart';

class B4IndexManager {
    late final Database _database;
    final String dbPath;
    Map<String, Map<String, dynamic>> _cache = {};
    int maxCacheSize = 10; // Default max cache size

    // Public getter for the cache
    Map<String, Map<String, dynamic>> get cache => _cache;

    Database get database => _database;

    B4IndexManager(this.dbPath) {
        _initializeDatabase().then((_) {
            schedulePurgeTask();
        });
    }
    // Initialize the database
    Future<void> _initializeDatabase() async {
        try {
            final directory = Directory('database');
            if (!directory.existsSync()) {
                directory.createSync();
            }

            final dbPath = 'database/init.db';
            _database = sqlite3.open(dbPath, mode: OpenMode.readWriteCreate);

            _database.execute('''
                              CREATE TABLE IF NOT EXISTS indexes (
                                  indexID INTEGER PRIMARY KEY AUTOINCREMENT,
                                  keyword TEXT,
                                  location TEXT,
                                  replicationFactor INTEGER,
                                  copyNo INTEGER,
                                  layerID INTEGER,
                                  status STRING,
                                  entryDateTime DATETIME,
                                  expirationDate DATETIME,
                                  publishTime DATETIME,
                                  republishTime DATETIME,
                                  timer TEXT DEFAULT '20m',
                                  lastUpdateTime DATETIME
                              )
                              ''');
                              _database.execute('''
                                                CREATE TABLE IF NOT EXISTS purge (
                                                    indexID INTEGER PRIMARY KEY AUTOINCREMENT,
                                                    keyword TEXT,
                                                    location TEXT,
                                                    replicationFactor INTEGER,
                                                    copyNo INTEGER,
                                                    layerID INTEGER,
                                                    status STRING,
                                                    entryDateTime DATETIME,
                                                    expirationDate DATETIME,
                                                    publishTime DATETIME,
                                                    republishTime DATETIME,
                                                    timer TEXT,
                                                    deletedAt DATETIME

                                                )
                                                ''');
                                                _database.execute('''
                                                        CREATE TABLE IF NOT EXISTS cache (
                                                                keyword TEXT PRIMARY KEY,
                                                                data TEXT,
                                                                expirationDate DATETIME
                                                        )
                                                        ''');

                                                        // Load cache from the database
                                                        final cacheEntries = _database.select('SELECT * FROM cache');
            for (final row in cacheEntries) {
            final String keyword = row['keyword'] as String;
                final Map<String, dynamic> data = json.decode(row['data'] as String);
                _cache[keyword] = data;
            }
        } catch (e) {
            print('Initialization error: $e');
        }
    }

    DateTime getDateTime() => DateTime.now();

    String dateToString(DateTime date) => date.toIso8601String();

    DateTime stringToDate(String dateStr) => DateTime.parse(dateStr);

    Future<void> insertIndex(Map<String, dynamic> indexData) async {
        try {
            final DateTime now = getDateTime();
            final String nowStr = dateToString(now);

            final String publishTime = indexData['publishTime'] ?? nowStr;
            final String lastUpdateTime = indexData['lastUpdateTime'] ?? nowStr;

            final DateTime expirationDate = indexData['lastUpdateTime'] == null
            ? stringToDate(indexData['entryDateTime']).add(Duration(days: 30))
            : stringToDate(indexData['lastUpdateTime']).add(Duration(days: 30));

            final DateTime republishTime = stringToDate(publishTime).add(
                Duration(
                    minutes: int.parse(
                        indexData['timer']?.replaceAll(RegExp(r'[^0-9]'), '') ?? '20')),
            );

            _database.execute(
                'INSERT OR REPLACE INTO indexes (keyword, location, replicationFactor, copyNo, layerID, status, '
                'entryDateTime, expirationDate, publishTime, republishTime, timer, lastUpdateTime) '
                'VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)',
                [
                    indexData['keyword'],
                    indexData['location'],
                    indexData['replicationFactor'],
                    indexData['copyNo'],
                    indexData['layerID'],
                    indexData['status'],
                    nowStr,
                    dateToString(expirationDate),
                    publishTime,
                    dateToString(republishTime),
                    indexData['timer'] ?? '20m',
                    lastUpdateTime,
                ],
            );

            // Initialize _cache if it's null
            _cache = <String, Map<String, dynamic>> {};
            // Check cache size before inserting new index
            if (_cache.length >= maxCacheSize) {
                print('Cache size exceeded maxCacheSize. Evicting entries.');
                _evictOldestCacheEntry();
            }
            // Add to cache with INSERT OR REPLACE to handle existing keywords
            _database.execute(
                'INSERT OR REPLACE INTO cache (keyword, data, expirationDate) VALUES (?, ?, ?)',
                [
                    indexData['keyword'],
                    json.encode(indexData),
                    dateToString(expirationDate)
                ],
            );

            // // Update cache if it exceeds max size
            // if (_cache.length > maxCacheSize) {
            //   print('Cache size exceeded maxCacheSize. Evicting entries.');
            //   _evictOldestCacheEntry();
            // }
        } catch (e) {
            print('SQLite Exception during insert: $e');
        }
    }

    void _evictOldestCacheEntry() {
        if (_cache.isNotEmpty) {
            final oldestKey = _cache.entries
                              .reduce((a, b) => a.value['timestamp'] < b.value['timestamp'] ? a : b)
                              .key;
            print('Evicting cache entry with key: $oldestKey');
            _cache.remove(oldestKey);
        }
    }

    Future<Map<String, dynamic>?> readByKeyword(String keyword) async {
        final DateTime newExpirationDate = getDateTime().add(Duration(days: 30));

        // Check the cache first
        if (_cache.containsKey(keyword)) {
            final cachedData = _cache[keyword]!;
            // Update expiration date in cache
            _cache[keyword] = {
                ...cachedData,
'expirationDate':
                dateToString(newExpirationDate),
            };

            // Update expiration date in the database cache table
            _database.execute(
                'INSERT OR REPLACE INTO cache (keyword, data, expirationDate) VALUES (?, ?, ?)',
                [
                    keyword,
                    json.encode(_cache[keyword]),
                    dateToString(newExpirationDate)
                ],
            );

            return cachedData;
        }

        // Check the indexes table
        final indexResult =
            _database.select('SELECT * FROM indexes WHERE keyword = ?', [keyword]);

        if (indexResult.isNotEmpty) {
            final row = indexResult.first;
            final result = {
'indexID':
                row['indexID'],
'keyword':
                row['keyword'],
'location':
                row['location'],
'replicationFactor':
                row['replicationFactor'],
'copyNo':
                row['copyNo'],
'layerID':
                row['layerID'],
'status':
                row['status'],
'entryDateTime':
                row['entryDateTime'],
'expirationDate':
                dateToString(newExpirationDate),
'publishTime':
                row['publishTime'],
'republishTime':
                row['republishTime'],
'timer':
                row['timer'],
'lastUpdateTime':
                row['lastUpdateTime'],
            };

            // Add to cache
            _cache[keyword] = result;
            _database.execute(
                'INSERT OR REPLACE INTO cache (keyword, data, expirationDate) VALUES (?, ?, ?)',
                [keyword, json.encode(result), dateToString(newExpirationDate)],
            );

            return result;
        }

        // Check the purge table
        final purgeResult =
            _database.select('SELECT * FROM purge WHERE keyword = ?', [keyword]);

        // If the index is in the purge table, return null
        if (purgeResult.isNotEmpty) {
            return null;
        }

        return null;
    }

    Future<void> updateIndex(
        Map<String, dynamic> indexData, String updatedLocation) async {
        try {
            final DateTime expirationDate = indexData['lastUpdateTime'] == null
            ? stringToDate(
                indexData['entryDateTime'] ?? DateTime.now().toString())
            .add(Duration(days: 30))
            : add24Hours(stringToDate(
                             indexData['lastUpdateTime'] ?? DateTime.now().toString()));

            final DateTime republishTime = add12Months(stringToDate(
                        indexData['publishTime'] ?? DateTime.now().toString()))
            .add(Duration(
                     minutes: int.parse(
                         indexData['timer']?.replaceAll(RegExp(r'[^0-9]'), '') ??
                         '20')));

            final existingIndex = _database.select(
                'SELECT * FROM indexes WHERE indexID = ?',
                [indexData['indexID']],
            );
            print('Existing Index: $existingIndex');
            if (existingIndex.isNotEmpty) {
                print('Updating index with ID: ${indexData['indexID']}');
                print('New Location: $updatedLocation');

                final sqlUpdate = '''
                UPDATE indexes SET keyword = ?, location = ?, replicationFactor = ?, copyNo = ?, layerID = ?, status = ?,
                entryDateTime = ?, expirationDate = ?, publishTime = ?, republishTime = ?, timer = ?, lastUpdateTime = ?
                WHERE indexID = ?
                ''';
                final params = [
                    indexData['keyword'] ?? '',
                    updatedLocation, // This should be updated
                    indexData['replicationFactor'] ?? 0,
                    indexData['copyNo'] ?? 0,
                    indexData['layerID'] ?? 0,
                    indexData['status'] ?? '',
                    indexData['entryDateTime'] ?? DateTime.now().toString(),
                    dateToString(expirationDate),
                    indexData['publishTime'] ?? DateTime.now().toString(),
                    dateToString(republishTime),
                    indexData['timer'] ?? '20m',
                    dateToString(getDateTime()),
                    indexData['indexID'],
                ];
                print('Executing SQL Update: $sqlUpdate with params $params');

                _database.execute(sqlUpdate, params);

                // Update the cache if the index is present
                print('Cache before update: $_cache');
                if (_cache.containsKey(indexData['keyword'])) {
                    _cache[indexData['keyword']] = {
                        ..._cache[indexData['keyword']]!,
'location':
                        updatedLocation, // Ensure cache is updated with new location
'lastUpdateTime':
                        dateToString(getDateTime()),
'expirationDate':
                        dateToString(expirationDate),
'timestamp':
                        getDateTime().millisecondsSinceEpoch, //Add a timestamp
                    };
                    print('Cache after update: $_cache');

                    _database.execute(
                        'INSERT OR REPLACE INTO cache (keyword, data, expirationDate) VALUES (?, ?, ?)',
                        [
                            indexData['keyword'],
                            json.encode(_cache[indexData['keyword']]),
                            dateToString(expirationDate)
                        ],
                    );
                }
            }
        } catch (e) {
            print('SQLite Exception during update: $e');
        }
    }

    Future<void> deleteIndex(String keyword) async {
        try {
            final deletedIndex = _database.select(
                'SELECT * FROM indexes WHERE keyword = ?',
                [keyword],
            );

            if (deletedIndex.isNotEmpty) {
                final now = getDateTime();

                final indexData = deletedIndex.first;
                _database.execute(
                    'INSERT INTO purge (keyword, location, replicationFactor, copyNo, layerID, status, entryDateTime, '
                    'expirationDate, publishTime, republishTime, timer,  deletedAt) '
                    'VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)',
                    [
                        indexData['keyword'],
                        indexData['location'],
                        indexData['replicationFactor'],
                        indexData['copyNo'],
                        indexData['layerID'],
                        indexData['status'],
                        indexData['entryDateTime'],
                        indexData['expirationDate'],
                        indexData['publishTime'],
                        indexData['republishTime'],
                        indexData['timer'],
                        dateToString(now)
                    ],
                );

                _database.execute(
                    'DELETE FROM indexes WHERE keyword = ?',
                    [keyword],
                );

                // Remove from cache
                _cache.remove(keyword);
                _database.execute('DELETE FROM cache WHERE keyword = ?', [keyword]);
            }
        } catch (e) {
            print('SQLite Exception during delete: $e');
        }
    }

    Future<void> purgeDeletedIndexes() async {
        try {
            final now = getDateTime();

            // Select indexes that need purging based on expiration date or deleted status
            final expiredIndexes = _database.select(
                'SELECT * FROM indexes WHERE expirationDate < ?',
                [dateToString(now)],
            );

            for (final index in expiredIndexes) {
                final keyword = index['keyword'];

                _database.execute(
                    'INSERT INTO purge (keyword, location, replicationFactor, copyNo, layerID, status, entryDateTime, '
                    'expirationDate, publishTime, republishTime, timer, lastUpdateTime, deletedAt) '
                    'VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)',
                    [
                        index['keyword'],
                        index['location'],
                        index['replicationFactor'],
                        index['copyNo'],
                        index['layerID'],
                        index['status'],
                        index['entryDateTime'],
                        index['expirationDate'],
                        index['publishTime'],
                        index['republishTime'],
                        index['timer'],
                        index['lastUpdateTime'],
                        dateToString(now),
                    ],
                );

                _database.execute('DELETE FROM indexes WHERE keyword = ?', [keyword]);

                // Remove from cache
                _cache.remove(keyword);
                _database.execute('DELETE FROM cache WHERE keyword = ?', [keyword]);
            }
        } catch (e) {
            print('SQLite Exception during purge: $e');
        }
    }

    void schedulePurgeTask() {
        Timer.periodic(Duration(hours: 24), (Timer timer) {
            purgeDeletedIndexes();
        });
    }

    // Helper function to add 24 hours to a DateTime
    DateTime add24Hours(DateTime dateTime) => dateTime.add(Duration(hours: 24));

    // Helper function to add 12 months to a DateTime
    DateTime add12Months(DateTime dateTime) {
        final int newYear = dateTime.year + (dateTime.month + 12) ~/ 12;
        final int newMonth = (dateTime.month + 12) % 12;
        final int newDay = dateTime.day;
        return DateTime(newYear, newMonth, newDay, dateTime.hour, dateTime.minute,
                        dateTime.second);
    }

    // New Method: Publish the index (adds publishTime)
    Future<void> publishIndex(String keyword) async {
        try {
            final DateTime now = getDateTime();
            final String nowStr = dateToString(now);

            _database.execute(
                'UPDATE indexes SET publishTime = ? WHERE keyword = ?',
                [nowStr, keyword],
            );

            // Update cache if the index is in the cache
            if (_cache.containsKey(keyword)) {
                final updatedData = {
                    ..._cache[keyword]!,
'publishTime':
                    nowStr,
                };

                _cache[keyword] = updatedData;

                _database.execute(
                    'INSERT OR REPLACE INTO cache (keyword, data, expirationDate) VALUES (?, ?, ?)',
                    [keyword, json.encode(updatedData), updatedData['expirationDate']],
                );
            }
        } catch (e) {
            print('SQLite Exception during publish: $e');
        }
    }

    // New Method: Republish the index (adds republishTime)
    Future<void> republishIndex(String keyword) async {
        try {
            final DateTime now = getDateTime();
            final String nowStr = dateToString(now);

            _database.execute(
                'UPDATE indexes SET republishTime = ? WHERE keyword = ?',
                [nowStr, keyword],
            );

            // Update cache if the index is in the cache
            if (_cache.containsKey(keyword)) {
                final updatedData = {
                    ..._cache[keyword]!,
'republishTime':
                    nowStr,
                };

                _cache[keyword] = updatedData;

                _database.execute(
                    'INSERT OR REPLACE INTO cache (keyword, data, expirationDate) VALUES (?, ?, ?)',
                    [keyword, json.encode(updatedData), updatedData['expirationDate']],
                );
            }
        } catch (e) {
            print('SQLite Exception during republish: $e');
        }
    }

    // New Method: Compute hash of the location string
    String computeHash(String location) {
        final bytes = utf8.encode(location);
        final digest = sha256.convert(bytes);
        return digest.toString();
    }

    void dispose() {
        _database.dispose(); // Ensure the database connection is closed
    }
}
